# ── Database ──────────────────────────────────────────────────────────
POSTGRES_USER=fren
POSTGRES_PASSWORD=fren-dev-password
POSTGRES_DB=fren
DATABASE_URL=postgresql+asyncpg://fren:fren-dev-password@db:5432/fren
FREN_DB_PORT=5452

# ── Ports ─────────────────────────────────────────────────────────────
FREN_BACKEND_PORT=8909

# ── Worker provider (z.ai coding plan — drives opencode workers) ──────
ZAI_API_KEY=your-zai-key-here
WORKER_MODEL=zai-coding-plan/glm-4.5-air
EXECUTION_BACKEND=direct

# ── Live / interactive provider (local OpenAI-compatible qwen) ────────
# The interactive chat layer runs here (z.ai can't drive LangChain).
LOCAL_LLM_BASE_URL=          # e.g. http://192.168.0.42:8082/v1
LOCAL_LLM_MODEL=qwen3.5-27b
LOCAL_LLM_API_KEY=not-needed
VLLM_API_KEY=not-needed

# ── Agents ────────────────────────────────────────────────────────────
# MUST NOT be /tmp — opencode produces no output from tmpfs.
AGENTS_DIR=/data/agents

# ── Telegram ──────────────────────────────────────────────────────────
BOT_TOKEN=
CHAT_ID=

# ── Auth ──────────────────────────────────────────────────────────────
JWT_SECRET=change-me
JWT_ALG=HS256
