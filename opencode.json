{
  "$schema": "https://opencode.ai/config.json",
  "model": "local-vllm-remote/qwen35-27b",
  "small_model": "local-vllm-remote/qwen35-27b",
  "provider": {
    "zai-coding-plan": {
      "options": {
        "apiKey": "{env:ZAI_API_KEY}"
      },
      "models": {
        "glm-4.7": {
          "id": "glm-4.7",
          "options": {
            "temperature": 0.6
          }
        },
        "glm-5.1": {
          "id": "glm-5.1",
          "options": {
            "temperature": 0.6
          }
        }
      }
    },
    "local-vllm-remote": {
      "options": {
        "apiKey": "env:VLLM_API_KEY",
        "baseURL": "http://192.168.0.42:8082/v1",
        "timeout": 1800000
      },
      "models": {
        "qwen35-27b": {
          "id": "cyankiwi/Qwen3.5-27B-AWQ-BF16-INT8",
          "reasoning": true,
          "interleaved": {
            "field": "reasoning_content"
          },
          "limits": {
            "context": 262144,
            "output": 32768
          },
          "options": {
            "temperature": 1.0,
            "topP": 0.95,
            "topK": 20
          }
        }
      }
    }
  }
}
