  "goals/strategy_analyzer" [fillcolor="#eef4ff"];
  "goals/strategy_creator" [fillcolor="#eef4ff"];
  "goals/task_categorizer" [fillcolor="#eef4ff"];
  "goals/winddown" [fillcolor="#eef4ff"];
  "persona/twily_selfie" [fillcolor="#eef4ff"];
  "persona/twily_videographer" [fillcolor="#eef4ff"];
  "workflows/todo" [fillcolor="#eef4ff"];
}