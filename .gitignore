# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Env / secrets — NEVER commit
.env
*.env
!.env.example
.google_token.json

# Compiled agent trees + runtime data
/data/
.opencode/
# .oac/snapshots/ = per-round candidate history (regenerable scratch); ignore.
# .oac/promoted/  = the WINNING improved prompts the fleet compiles from — these
# are real artifacts of autoresearch and ARE tracked (committed), so the
# improved fleet is reproducible without re-running the loop.
.oac/snapshots/
# Local smoke-test / scratch compiled fleets
.smoke_agents/
*.smoke/
# Scheduler / run state written at runtime
run_logs/
/config/one_time_schedule.yml
data/scheduler_state.json
# OAuth tokens materialised at runtime (any account suffix)
.google_token*.json

# Node (dashboard/frontend)
node_modules/
dist/

# OS / editor cruft
.DS_Store
*.swp
*~

# autoresearch run log (transient)
.autoresearch.log

# autoloop opencode workspace (approach A)
backend/.oac/autoloop_ws/
.oac/autoloop_ws/

.oac/probe_cache.json
